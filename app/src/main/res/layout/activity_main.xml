<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	xmlns:app="http://schemas.android.com/apk/res-auto"
	android:id="@+id/activity_mainLinearLayout"
	android:focusable="true"
	android:focusableInTouchMode="true"
	android:layout_width="fill_parent"
	android:layout_height="fill_parent"
	android:background="#002b2d"
	android:paddingBottom="0dp"
	android:orientation="vertical">

	<RelativeLayout
		android:layout_marginTop="15dp"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content">

		<TextView
			android:textSize="12.0sp"
			android:textStyle="bold"
			android:textColor="#F6F7E4"
			android:id="@+id/config_version_info"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginLeft="10.0dip"
			android:layout_alignParentLeft="true"
			android:layout_marginTop="10dp"/>

		<TextView
			android:textSize="12.0sp"
			android:textStyle="bold"
			android:textColor="#F6F7E4"
			android:id="@+id/app_info"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:layout_marginRight="10.0dip"
			android:layout_alignParentRight="true"
			android:layout_marginTop="20dp"/>

		<ImageView
			android:layout_width="fill_parent"
			android:layout_height="75.0dip"
			android:layout_marginBottom="5.0dip"
			android:src="@drawable/icon"
			android:scaleType="centerInside"
			android:cropToPadding="true"
			android:layout_marginTop="30dp"/>

	</RelativeLayout>

	<LinearLayout
		android:gravity="bottom|center"
		android:orientation="horizontal"
		android:layout_width="wrap_content"
		android:layout_height="wrap_content">

		<View
			android:background="#F6F7E4"
			android:layout_width="fill_parent"
			android:layout_height="1.0dip"
			android:layout_weight="1.0"/>

		<RelativeLayout
			android:layout_width="wrap_content"
			android:layout_height="wrap_content">

			<TextView
				android:textSize="10.0sp"
				android:typeface="serif"
				android:textStyle="bold"
				android:textColor="#F6F7E4"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginLeft="5.0dip"
				android:layout_marginRight="5.0dip"
				android:text="ESTADO"/>

		</RelativeLayout>

		<View
			android:background="#F6F7E4"
			android:layout_width="fill_parent"
			android:layout_height="1.0dip"
			android:layout_weight="1.0"/>

	</LinearLayout>

	<LinearLayout
		android:orientation="horizontal"
		android:padding="5.0dip"
		android:layout_width="fill_parent"
		android:layout_height="wrap_content">

		<LinearLayout
			android:gravity="center"
			android:orientation="horizontal"
			android:id="@+id/sentHeaderRow"
			android:padding="4.0dip"
			android:layout_width="fill_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="3.0dip"
			android:layout_marginRight="20.0dip"
			android:layout_weight="1.0">

			<ImageView
				android:layout_width="20.0dip"
				android:layout_height="20.0dip"
				android:layout_marginRight="5.0dip"
				android:src="@drawable/ic_cloud_upload"/>

			<TextView
				android:textSize="10.0dip"
				android:textStyle="bold"
				android:textColor="#F6F7E4"
				android:id="@+id/TX"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="0 MB"/>

		</LinearLayout>

		<RelativeLayout
			android:orientation="horizontal"
			android:layout_width="wrap_content"
			android:layout_height="wrap_content">

			<Chronometer
				android:id="@+id/cmTimer"
				android:textSize="10.0dip"
				android:textStyle="bold"
				android:textColor="#F6F7E4"
				android:gravity="center_horizontal"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginBottom="18.0dip"
				android:layout_centerHorizontal="true"
				android:textAlignment="center"
				android:text="⏱️"/>

			<TextView
				android:textStyle="bold"
				android:textColor="#F6F7E4"
				android:gravity="center"
				android:textSize="10.0sp"
				android:id="@+id/status1"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:layout_marginTop="18.0dip"
				android:text="DESCONECTADO"/>

		</RelativeLayout>

		<LinearLayout
			android:gravity="center"
			android:orientation="horizontal"
			android:id="@+id/receivedHeaderRow"
			android:padding="4.0dip"
			android:layout_width="fill_parent"
			android:layout_height="wrap_content"
			android:layout_marginLeft="20.0dip"
			android:layout_marginTop="3.0dip"
			android:layout_weight="1.0">

			<ImageView
				android:layout_width="20.0dip"
				android:layout_height="20.0dip"
				android:layout_marginRight="5.0dip"
				android:src="@drawable/ic_cloud_download"/>

			<TextView
				android:textSize="10.0dip"
				android:textStyle="bold"
				android:textColor="#F6F7E4"
				android:gravity="right"
				android:id="@+id/RX"
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="0 MB"/>

		</LinearLayout>

	</LinearLayout>

	<View
		android:background="#F6F7E4"
		android:layout_width="fill_parent"
		android:layout_height="1.0dip"/>

	<LinearLayout
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:gravity="center"
		android:orientation="vertical"
		android:layout_alignParentLeft="true"
		android:layout_alignParentStart="true"
		android:padding="2dp"
		android:layout_marginRight="5dp"
		android:layout_marginLeft="5dp">

		<LinearLayout
			android:orientation="vertical"
			android:layout_width="match_parent"
			android:layout_height="wrap_content">

			<LinearLayout
				android:orientation="vertical"
				android:layout_width="match_parent"
				android:layout_height="wrap_content">

				<LinearLayout
					android:orientation="vertical"
					android:layout_width="match_parent"
					android:layout_height="wrap_content"
					android:padding="5dp"
					android:gravity="center">

					<include
						layout="@layout/servidores"/>

				</LinearLayout>

			</LinearLayout>

		</LinearLayout>

		<LinearLayout
			android:id="@+id/activity_mainInputPasswordLayout"
			android:layout_height="wrap_content"
			android:layout_width="match_parent"
			android:orientation="vertical"
			android:gravity="center"
			android:paddingTop="10dp"
			android:paddingLeft="20dp"
			android:paddingRight="20dp"
			android:paddingBottom="5dp"
			android:layout_gravity="center"
			android:visibility="gone">

			<LinearLayout
				android:layout_height="wrap_content"
				android:layout_width="match_parent"
				android:orientation="horizontal"
				android:gravity="center"
				android:layout_marginBottom="10dp"
				android:paddingBottom="10dp">

				<TextView
					android:layout_height="wrap_content"
					android:layout_width="wrap_content"
					android:text="@string/title_login_main"
					android:textStyle="bold"
					android:textSize="18sp"
					android:textColor="@color/colorText"/>

			</LinearLayout>

			<android.support.design.widget.TextInputLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_gravity="center">

				<android.support.design.widget.TextInputEditText
					android:id="@+id/activity_mainInputPasswordUserEdit"
					android:layout_height="wrap_content"
					android:layout_width="match_parent"
					android:ems="20"
					android:singleLine="true"
					android:drawableStart="@drawable/ic_person_black_24dp"
					android:textColor="@color/colorText"
					android:hint="@string/auth_username"/>

			</android.support.design.widget.TextInputLayout>

			<RelativeLayout
				android:layout_height="wrap_content"
				android:layout_width="match_parent"
				android:layout_marginTop="4dp"
				android:layout_marginLeft="4dp"
				android:layout_marginRight="4dp"
				android:layout_marginBottom="4dp"
				android:orientation="horizontal">

				<android.support.design.widget.TextInputLayout
					android:id="@+id/fragment_userpassTextInputLayout"
					android:layout_width="match_parent"
					android:layout_height="wrap_content">

					<android.support.design.widget.TextInputEditText
						android:id="@+id/activity_mainInputPasswordPassEdit"
						android:inputType="textPassword"
						android:textColor="@color/colorText"
						android:drawableStart="@drawable/ic_lock_black_24dp"
						android:ems="20"
						android:singleLine="true"
						android:layout_width="match_parent"
						android:layout_height="wrap_content"
						android:hint="@string/password"/>

				</android.support.design.widget.TextInputLayout>

				<LinearLayout
					android:layout_height="wrap_content"
					android:layout_width="wrap_content"
					android:orientation="vertical"
					android:layout_alignEnd="@id/fragment_userpassTextInputLayout">

					<ImageButton
						android:id="@+id/activity_mainInputShowPassImageButton"
						android:src="@drawable/ic_visibility_off_black_24dp"
						android:layout_width="wrap_content"
						android:layout_height="wrap_content"
						android:hint="@string/show_password"
						android:layout_gravity="right"/>

				</LinearLayout>

			</RelativeLayout>

		</LinearLayout>

		<LinearLayout
			android:layout_height="wrap_content"
			android:layout_width="match_parent"
			android:orientation="horizontal">

			<Button
				android:id="@+id/activity_starterButtonMain"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginLeft="80dp"
				android:layout_marginRight="80dp"
				android:background="@drawable/start"
				android:textColor="#002b2d"
				android:textStyle="bold"
				android:text="@string/start"
				android:layout_gravity="center"
				android:layout_marginTop="5dp"
				android:layout_marginBottom="10dp"/>

		</LinearLayout>

		<LinearLayout
			android:layout_height="wrap_content"
			android:layout_width="230dp"
			android:orientation="horizontal"
			android:layout_gravity="center"
			android:visibility="gone">

			<Button
				android:layout_height="wrap_content"
				android:layout_width="wrap_content"
				android:text="reset"
				android:layout_marginLeft="17dp"
				android:id="@+id/button_reset"
				android:visibility="gone"/>

		</LinearLayout>

	</LinearLayout>

	<LinearLayout
		android:layout_height="wrap_content"
		android:layout_width="match_parent"
		android:orientation="vertical"
		android:gravity="center">

		<com.google.android.gms.ads.AdView
			xmlns:ads="http://schemas.android.com/apk/res-auto"
			android:id="@+id/adBannerMainView"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_centerHorizontal="true"
			android:layout_alignParentBottom="true"
			ads:adSize="SMART_BANNER"
			ads:adUnitId="ca-app-pub-2189210403819582/9095763417"
			android:layout_gravity="center"
			android:layout_marginTop="5dp"
			android:visibility="visible">

		</com.google.android.gms.ads.AdView>

		<LinearLayout
			android:id="@+id/activity_mainInputPayloadLinearLayout"
			android:layout_height="wrap_content"
			android:layout_width="wrap_content"
			android:orientation="vertical"
			android:layout_marginTop="3dp"
			android:padding="10dp"
			android:visibility="gone">

			<android.support.design.widget.TextInputLayout
				android:layout_width="match_parent"
				android:visibility="gone"
				android:layout_height="wrap_content">

				<android.support.design.widget.TextInputEditText
					android:id="@+id/activity_mainInputPayloadEditText"
					android:inputType="textMultiLine|textLongMessage"
					android:layout_width="fill_parent"
					android:layout_height="wrap_content"
					android:visibility="gone"
					android:ems="20"
					android:textColor="@color/colorText"
					android:hint="@string/payload"/>

			</android.support.design.widget.TextInputLayout>

		</LinearLayout>

	</LinearLayout>

	<LinearLayout
		android:id="@+id/activity_mainMetodoConexaoLayout"
		android:layout_height="wrap_content"
		android:layout_width="wrap_content"
		android:orientation="vertical"
		android:gravity="center"
		android:padding="5dp"
		android:layout_marginTop="3dp"
		android:visibility="gone">

		<TextView
			android:id="@+id/activity_mainMetodoConexaoText"
			android:layout_height="wrap_content"
			android:layout_width="wrap_content"
			android:visibility="gone"
			android:text="@string/method_connection"
			android:textStyle="bold"/>

		<RadioGroup
			android:id="@+id/activity_mainMetodoConexaoRadio"
			android:layout_height="wrap_content"
			android:layout_width="match_parent"
			android:orientation="horizontal"
			android:visibility="gone"
			android:breakStrategy="balanced"
			android:gravity="center">

			<android.support.v7.widget.AppCompatRadioButton
				android:id="@+id/activity_mainSSHDirectRadioButton"
				android:layout_height="wrap_content"
				android:layout_width="wrap_content"
				android:hint="SSH DIRECT"
				android:padding="5dp"/>

			<android.support.v7.widget.AppCompatRadioButton
				android:id="@+id/activity_mainSSHProxyRadioButton"
				android:layout_height="wrap_content"
				android:layout_width="wrap_content"
				android:hint="SSH + PROXY"/>

		</RadioGroup>

		<android.support.v7.widget.SwitchCompat
			android:id="@+id/activity_mainCustomPayloadSwitch"
			android:layout_height="wrap_content"
			android:layout_width="wrap_content"
			android:hint="Custom Payload"
			android:visibility="gone"
			android:layout_gravity="right"/>

	</LinearLayout>

	<LinearLayout
		android:id="@+id/activity_mainInputProxyLayout"
		android:layout_height="wrap_content"
		android:layout_width="wrap_content"
		android:orientation="horizontal"
		android:padding="5dp"
		android:layout_marginTop="3dp"
		android:visibility="gone"
		android:gravity="center_horizontal">

		<LinearLayout
			android:layout_height="wrap_content"
			android:layout_width="wrap_content"
			android:orientation="vertical"
			android:paddingRight="10dp"
			android:visibility="gone"
			android:paddingLeft="10dp"
			android:layout_gravity="start">

			<TextView
				android:layout_height="wrap_content"
				android:layout_width="wrap_content"
				android:text="@string/proxy_remote"
				android:visibility="gone"
				android:textStyle="bold"/>

			<TextView
				android:id="@+id/activity_mainProxyText"
				android:layout_height="wrap_content"
				android:layout_width="wrap_content"
				android:visibility="gone"
				android:text="@string/no_value"/>

		</LinearLayout>

		<LinearLayout
			android:layout_height="match_parent"
			android:layout_width="fill_parent"
			android:orientation="vertical"
			android:visibility="gone"
			android:layout_gravity="right">

			<ImageView
				android:layout_height="match_parent"
				android:layout_width="30dp"
				android:visibility="gone"
				android:src="@drawable/ic_mode_edit_black_48dp"
				android:layout_gravity="end"/>

		</LinearLayout>

	</LinearLayout>

	<LinearLayout
		android:id="@+id/activity_mainMensagemConfigLinearLayout"
		android:layout_height="wrap_content"
		android:layout_width="match_parent"
		android:orientation="vertical"
		android:layout_margin="5dp"
		android:background="@drawable/background_rounded"
		android:padding="10dp"
		android:visibility="gone">

		<TextView
			android:id="@+id/activity_mainMensagemConfigTextView"
			android:layout_height="wrap_content"
			android:layout_width="wrap_content"
			android:autoLink="web"/>

	</LinearLayout>

	<include
		layout="@layout/bottom_jomzdev"/>

</LinearLayout>


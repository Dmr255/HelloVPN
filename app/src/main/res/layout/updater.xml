<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:orientation="vertical"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:gravity="top|center">

	<RelativeLayout
		android:layout_width="match_parent"
		android:layout_height="130dp"
		android:id="@+id/newupdateRelativeLayout1"
		android:background="#002b2d">

		<RelativeLayout
			android:layout_width="60dp"
			android:layout_height="60dp"
			android:layout_alignParentTop="true"
			android:layout_centerInParent="true"
			android:background="@drawable/ic_cloud_download"
			android:layout_marginTop="20dp"/>

		<TextView
			android:layout_width="wrap_content"
			android:layout_height="wrap_content"
			android:text="MODOS DE ACTUALIZAR"
			android:textAppearance="?android:attr/textAppearanceMedium"
			android:layout_centerInParent="true"
			android:textColor="#F6F7E4"
			android:layout_alignParentBottom="true"
			android:layout_marginBottom="10dp"
			android:background="#002b2d"/>

	</RelativeLayout>

	<LinearLayout
		android:orientation="vertical"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		android:padding="10dp">

		<LinearLayout
			android:orientation="vertical"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="10dp"
			android:gravity="center"
			android:layout_marginBottom="10dp">

			<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="CONFIGURACIÓN DE LA RED"
				android:textColor="#002b2d"
				android:textSize="15sp"/>

		</LinearLayout>

		<LinearLayout
			android:orientation="horizontal"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:gravity="center">

			<RelativeLayout
				android:layout_width="140dp"
				android:layout_height="40dp"
				android:gravity="center">

				<Button
					android:layout_width="120dp"
					android:layout_height="35dp"
					android:layout_gravity="center"
					style="@style/dialog_blue_button"
					android:textColor="#F6F7E4"
					android:text="ONLINE"
					android:onClick="onlinez"/>

			</RelativeLayout>

			<RelativeLayout
				android:layout_width="140dp"
				android:layout_height="40dp"
				android:gravity="center"
				android:layout_marginLeft="10dp">

				<Button
					android:layout_width="120dp"
					android:layout_height="35dp"
					style="@style/dialog_blue_button"
					android:textColor="#F6F7E4"
					android:layout_gravity="center"
					android:text="OFFLINE"
					android:onClick="offlinez"/>

			</RelativeLayout>

		</LinearLayout>

		<LinearLayout
			android:orientation="vertical"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="15dp"
			android:gravity="center"
			android:layout_marginBottom="10dp">

			<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="VERSIÓN DE LA APLICACIÓN"
				android:textColor="#002b2d"
				android:textSize="15sp"/>

		</LinearLayout>

		<LinearLayout
			android:orientation="horizontal"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:gravity="center">

			<RelativeLayout
				android:layout_width="140dp"
				android:layout_height="40dp"
				android:gravity="center">

				<Button
					android:layout_width="120dp"
					android:layout_height="35dp"
					style="@style/dialog_blue_button"
					android:textColor="#F6F7E4"
					android:layout_gravity="center"
					android:text="VERIFICAR"
					android:onClick="appupdate"/>

			</RelativeLayout>

		</LinearLayout>

		<LinearLayout
			android:orientation="vertical"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:layout_marginTop="15dp"
			android:gravity="center"
			android:layout_marginBottom="10dp">

			<TextView
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="BORRAR CACHÉ"
				android:textColor="#002b2d"
				android:textSize="15sp"/>

		</LinearLayout>

		<LinearLayout
			android:orientation="horizontal"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:gravity="center">

			<RelativeLayout
				android:layout_width="140dp"
				android:layout_height="40dp"
				android:gravity="center">

				<Button
					android:layout_width="120dp"
					android:layout_height="35dp"
					style="@style/dialog_blue_button"
					android:textColor="#F6F7E4"
					android:layout_gravity="center"
					android:text="BORRAR"
					android:onClick="clearz"/>

			</RelativeLayout>

		</LinearLayout>

		<LinearLayout
			android:orientation="horizontal"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:gravity="right"
			android:layout_marginTop="15dp"
			android:padding="10dp">

			<Button
				android:text="SALIR"
				android:textColor="#F6F7E4"
				style="@style/dialog_blue_button"
				android:id="@+id/close"
				android:layout_height="35dp"/>

		</LinearLayout>

	</LinearLayout>

</LinearLayout>

